{
  "manifest_version": 3,
  "name": "Student Second Brain",
  "version": "1.0",
  "description": "Capture anything to Notion with one click",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "http://localhost:5000/*",
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Student Second Brain",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
