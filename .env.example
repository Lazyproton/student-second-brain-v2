# ============================================================
# SETUP INSTRUCTIONS
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real values in .env
# 3. NEVER commit .env to GitHub — it is gitignored
# 4. Get OPENROUTER_API_KEY from: https://openrouter.ai
# 5. Get NOTION_TOKEN from: Notion Settings → Integrations
# 6. Get Database IDs from the Notion page URL
# ============================================================

# ------------------------------------------------------------
# LLM — OpenRouter API
# Get your key at: https://openrouter.ai → Dashboard → Keys
# ------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM model to use — change this to swap models without touching any code
# Browse available free models at: https://openrouter.ai/models?q=free
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ------------------------------------------------------------
# Notion Integration Token
# Go to: https://www.notion.so/my-integrations → New integration
# Copy the "Internal Integration Secret"
# ------------------------------------------------------------
NOTION_TOKEN=your_notion_integration_token_here

# ------------------------------------------------------------
# Notion Database IDs
# Open the database in Notion → copy the URL
# The ID is the 32-character string between the last / and the ?
# Example URL: https://notion.so/workspace/abc123...def456?v=...
#                                           ^^^^^^^^^^^^^^^^ this part
# ------------------------------------------------------------

# ID of the "Student Notes" database
NOTION_NOTES_DB_ID=your_student_notes_database_id_here

# ID of the "CP Tracker" database
NOTION_CP_DB_ID=your_cp_tracker_database_id_here

# ID of the Notion Calendar database (for exam/event dates)
NOTION_CALENDAR_DB_ID=your_notion_calendar_database_id_here

# ID of the Master Index database (tracks all per-subject database IDs)
# Schema: "Subject Name" (title), "Database ID" (rich_text), "Created At" (date)
NOTION_MASTER_INDEX_DB_ID=your_master_index_database_id_here

# ID of the Notion page where new subject databases will be created as children
NOTION_PARENT_PAGE_ID=your_parent_page_id_here

# ------------------------------------------------------------
# Flask Server Config
# ------------------------------------------------------------

# Port the Flask backend listens on (default: 5000)
FLASK_PORT=5000

# Set to True during development, False in production
FLASK_DEBUG=True
